.SUFFIXES:
.SUFFIXES: .H .C .o

SHELL		= /bin/sh

# macOS paths: OpenMotif via Homebrew, X11 via XQuartz

MOTIF_CFLAGS	= -I/opt/homebrew/include
MOTIF_LIBS	= -L/opt/homebrew/lib -lXm

X11_CFLAGS	= -I/opt/X11/include
X11_LIBS	= -L/opt/X11/lib -lXt -lX11 -lXext

NET_LIBS	=

# Define destination directories for targets relative to source directories

DSTINCDIR	= ../../include
DSTLIBDIR	= ../../lib
DSTBINDIR	= ../../bin

RELMANDIR	= /usr/local/man/man1
RELBINDIR	= /usr/local/bin
RELSHRDIR	= /usr/local/share/BattleTris
RELDEFDIR	= /usr/local/share/X11/app-defaults

# Define base flags to be used in Makefiles

BT_CXXFLAGS	= -DNDEBUG -g -std=c++14 -Wno-deprecated-declarations
BT_IFLAGS	= -I. -I$(DSTINCDIR)
BT_LDFLAGS	= -L. -L$(DSTLIBDIR)

# Define pathnames of needed utilities

CXX		= clang++
AR		= ar -ru
RANLIB		= ranlib
INSTALL		= /bin/sh ../../bin/install-sh -c
RM		= rm -rf

$(DSTINCDIR)/%.H: %.H
	$(INSTALL) -m 0444 $< $@
